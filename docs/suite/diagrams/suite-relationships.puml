@startuml suite-relationships
skinparam componentStyle rectangle
skinparam backgroundColor #FEFEFE
title Courseforge suite — how repositories relate

package "courseforge" {
  [course-builder\n(main application)] as CB
  [infrastructure\n(orchestration & publish)] as INF
  [github.io\n(public GitHub Pages site)] as PAGES
}

package "jmjava" {
  [documentation-generator\n(docgen library + suite handbook)] as DG
  [tekton-dag\n(Tekton DAG / build engine)] as TD
}

INF -down-> TD : pins versions,\nreuse docs
INF -down-> DG : pins docgen SHA
INF -down-> CB : suite CI,\nverify access
INF -down-> PAGES : publish-github-io\n(sync + aggregate)
CB -right-> DG : docgen bundles\n(`docs/demos`, `docs/rendered-site`)
DG ..> PAGES : `docs/suite/` handbook\nsynced into Pages
TD ..> CB : build / clone tasks\n(consumer-defined)

note right of PAGES
  Visitors authenticate via
  the site passphrase gate, then
  browse handbook + video docs.
end note

@enduml
